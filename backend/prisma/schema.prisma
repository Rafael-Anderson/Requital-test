generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model order {
  id                 Int                  @id @default(autoincrement())
  shopId             Int
  customerEmail      String
  status             String               @default("Pending")
  paymentStatus      String               @default("Pending")
  total              Decimal
  createdAt          DateTime             @default(now())
  shop               shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade, map: "Order_shopId_fkey")
  orderitem          orderitem[]
  paymenttransaction paymenttransaction[]

  @@index([shopId], map: "Order_shopId_fkey")
}

model orderitem {
  id               Int     @id @default(autoincrement())
  orderId          Int
  productVariantId Int
  quantity         Int
  priceAtPurchase  Decimal
  order            order   @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "OrderItem_orderId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
}

model paymenttransaction {
  id               Int      @id @default(autoincrement())
  orderId          Int
  gateway          String
  gatewayReference String
  amount           Decimal
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  order            order    @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "PaymentTransaction_orderId_fkey")

  @@index([orderId], map: "PaymentTransaction_orderId_fkey")
}

model product {
  id             Int              @id @default(autoincrement())
  shopId         Int
  name           String
  description    String?
  price          Decimal
  costPrice      Decimal
  sku            String
  category       String?
  createdAt      DateTime         @default(now())
  shop           shop             @relation(fields: [shopId], references: [id], onDelete: Cascade, map: "Product_shopId_fkey")
  productvariant productvariant[]

  @@unique([shopId, sku], map: "Product_shopId_sku_key")
}

model productvariant {
  id            Int      @id @default(autoincrement())
  productId     Int
  attributes    String?
  stockQty      Int      @default(0)
  priceOverride Decimal?
  product       product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductVariant_productId_fkey")

  @@index([productId], map: "ProductVariant_productId_fkey")
}

model shop {
  id            Int            @id @default(autoincrement())
  name          String
  subdomain     String         @unique(map: "Shop_subdomain_key")
  currency      String         @default("AED")
  createdAt     DateTime       @default(now())
  order         order[]
  product       product[]
  themesettings themesettings?
  user          user[]
}

model themesettings {
  id         Int     @id @default(autoincrement())
  shopId     Int     @unique(map: "ThemeSettings_shopId_key")
  templateId Int?
  logoUrl    String?
  bannerUrl  String?
  brandColor String?
  heroText   String?
  shop       shop    @relation(fields: [shopId], references: [id], onDelete: Cascade, map: "ThemeSettings_shopId_fkey")
}

model user {
  id           Int      @id @default(autoincrement())
  shopId       Int
  email        String
  passwordHash String
  role         String   @default("merchant")
  createdAt    DateTime @default(now())
  shop         shop     @relation(fields: [shopId], references: [id], onDelete: Cascade, map: "User_shopId_fkey")

  @@unique([shopId, email], map: "User_shopId_email_key")
}
